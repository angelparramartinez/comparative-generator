  "dependency_set_translation_cases": [
    {
      "id": "VM-SET-001",
      "description": "Caso real (cover 15, 22/07): 1 dependencia no-enum (continent>0, no es un fallo) + 1 enum totalmente traducida (housingUse IN) + 1 enum con fallo real (housingUse NOT_IN [\"otros usos\"], known_limitation) -- dependencies_translated debe tener 2 elementos (excluye SOLO la tercera), fully_translated agregado debe ser false (para que review_assembly siga pudiendo marcar needs_review).",
      "dependencies": [
        {
          "risk_field": "continent",
          "operator": ">",
          "value": 0
        },
        {
          "risk_field": "housingUse",
          "operator": "IN",
          "value": [
            "vivienda principal",
            "vivienda secundaria"
          ]
        },
        {
          "risk_field": "housingUse",
          "operator": "NOT_IN",
          "value": [
            "otros usos"
          ]
        }
      ],
      "expected_dependencies_translated": [
        {
          "risk_field": "continent",
          "operator": ">",
          "value": 0
        },
        {
          "risk_field": "housingUse",
          "operator": "IN",
          "value": [
            "MainResidence",
            "SecondHome"
          ]
        }
      ],
      "expected_fully_translated": false
    }
