  "pipeline_integration_cases": [
    {
      "id": "VM-PIPE-001",
      "source_case_refs": [
        "GD-FP-001"
      ],
      "dependency": {
        "risk_field": "housingRegime",
        "operator": "=",
        "value": "propietario"
      },
      "expected_final_spel": "insurance[\"risk\"].housingRegime == 'Owner'"
    },
    {
      "id": "VM-PIPE-002",
      "source_case_refs": [
        "GD-HALLUC-001",
        "GD-HALLUC-002",
        "GD-HALLUC-003",
        "GD-HALLUC-004"
      ],
      "dependency": {
        "risk_field": "housingUse",
        "operator": "IN",
        "value": [
          "vivienda principal",
          "vivienda secundaria"
        ]
      },
      "expected_final_spel": "insurance[\"risk\"].housingUse in {'MainResidence','SecondHome'}"
    },
    {
      "id": "VM-PIPE-003",
      "source_case_refs": [
        "GD-REF-007"
      ],
      "dependency": {
        "risk_field": "capitalInsuranceType",
        "operator": "NOT_IN",
        "value": [
          "primer riesgo"
        ]
      },
      "expected_final_spel": "!(insurance[\"risk\"].capitalInsuranceType in {'FirstRisk'})"
    }
