{
  "version": "1.0",
  "dataset_name": "coverage_insert_generator_tuning_key_golden_set",
  "description": "Golden set del matcher texto-Excel (hoja Coberturas opcionales, Generali Hogar) -> tuning_key, usando el diccionario real examples/tuning_generali_traducido.json aportado por el usuario.",
  "source_tuning_file": "examples/tuning_generali_traducido.json",
  "source_excel": "examples/Plantilla Comparativa Hogar.xlsx (hoja Coberturas opcionales)",
  "schema_notes": {
    "expected_tuning_key": "key real del diccionario de tuning, o \"NOT_FOUND\" si no existe ningun campo relacionado.",
    "expected_confidence": "alta | media -- alta = deberia acertar siempre; media = casos con variacion lexica real (preposicion, sufijo, envoltorio) donde el heuristico puede necesitar mas contexto/LLM."
  },
  "cases": [
    {
      "id": "GD-TUNE-001",
      "cover_name": "Recuperación de la vivienda ocupada por allanamiento de morada",
      "expected_tuning_key": "ycodpo",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-002",
      "cover_name": "Cargador vehículo eléctrico o híbrido",
      "expected_tuning_key": "zasite",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-003",
      "cover_name": "Daños a placas solares y otros sistemas de energía renovable",
      "expected_tuning_key": "zasihb",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-004",
      "cover_name": "Avería a placas solares y otros sistemas de energía renovable",
      "expected_tuning_key": "zimpac",
      "expected_confidence": "media",
      "notes": "label real dice 'Averia DE placas...' (preposicion distinta)"
    },
    {
      "id": "GD-TUNE-005",
      "cover_name": "Reconstrucción de jardín",
      "expected_tuning_key": "qrjard",
      "expected_confidence": "media",
      "notes": "label real es plural 'Reconstruccion de jardines'; existe tambien zrjard 'jardin singular' como posible confusor"
    },
    {
      "id": "GD-TUNE-006",
      "cover_name": "Reconstrucción de jardín singular",
      "expected_tuning_key": "zrjard",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-007",
      "cover_name": "Muebles de exterior",
      "expected_tuning_key": "ztcar",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-008",
      "cover_name": "Todo riesgo accidental",
      "expected_tuning_key": "ztract",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-009",
      "cover_name": "Todo riesgo de equipos tecnológicos",
      "expected_tuning_key": "zdacon",
      "expected_confidence": "media",
      "notes": "label real anade sufijo '(franq. 200E)'"
    },
    {
      "id": "GD-TUNE-010",
      "cover_name": "Mascotas (Accidentes de perros y otras mascotas)",
      "expected_tuning_key": "zresid",
      "expected_confidence": "media",
      "notes": "cover_name envuelve el label real entre parentesis con prefijo Mascotas"
    },
    {
      "id": "GD-TUNE-011",
      "cover_name": "Responsabilidad civil por propiedad y tenencia de perros",
      "expected_tuning_key": "qrcand",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-012",
      "cover_name": "RC perros peligrosos o de difícil manejo",
      "expected_tuning_key": "NOT_FOUND",
      "expected_confidence": "alta",
      "notes": "no existe ningun campo de tuning para esta cobertura especifica (wpobl es un contador de perros, no un interruptor de esta cobertura) -- caso real de NOT_FOUND"
    },
    {
      "id": "GD-TUNE-013",
      "cover_name": "Daños malintencionados del inquilino",
      "expected_tuning_key": "yvig24",
      "expected_confidence": "alta",
      "notes": "label dinamico (SPEL ternario) que expone este literal exacto como una de sus dos opciones"
    },
    {
      "id": "GD-TUNE-014",
      "cover_name": "Daños malintencionados del inquilino turística",
      "expected_tuning_key": "yvig24",
      "expected_confidence": "alta",
      "notes": "mismo campo yvig24, la otra rama del ternario"
    },
    {
      "id": "GD-TUNE-015",
      "cover_name": "Bricohogar",
      "expected_tuning_key": "zrobef",
      "expected_confidence": "alta",
      "notes": "label identico"
    },
    {
      "id": "GD-TUNE-016",
      "cover_name": "Control de plagas",
      "expected_tuning_key": "znclas",
      "expected_confidence": "alta",
      "notes": "label identico salvo mayusculas (Control de Plagas)"
    }
  ],
  "tuning_dictionary": {
    "commercialDiscountNumber": {
      "allowSavedTuning": true,
      "component": "number",
      "label": "Descuento comercial %",
      "max": 100,
      "min": -100,
      "required": false,
      "section": "section.discounts",
      "step": 1,
      "suffix": "/tuning?.commercialDiscountNumber < 0 ? { 'text': 'Recargo', 'style': 'warning' } : {}/",
      "type": "number",
      "value": 0
    },
    "jewelryInQuote": {
      "component": "radio",
      "label": "Joyas en caja fuerte con valor unitario igual o superior a 6.000€",
      "options": [
        {
          "items": [
            {
              "label": "si",
              "value": "S"
            },
            {
              "label": "no",
              "value": "N"
            }
          ]
        }
      ],
      "required": "/#this?.stage == 'preissuance' && insurance.risk.jewelsInSafeBoxLimit > 5999/",
      "section": "section.additionalData",
      "type": "string",
      "value": null,
      "visible": "/insurance.risk.jewelsInSafeBoxLimit > 5999/"
    },
    "jewelryInQuoteAmmount": {
      "component": "number",
      "label": "Suma de los importes de las Joyas en caja fuerte con valor unitario igual o superior a 6.000€",
      "max": "/insurance.risk.jewelsInSafeBoxLimit/",
      "min": "/tuning?.jewelryInQuote == 'S' ? 6000 : 0/",
      "required": "/tuning?.jewelryInQuote == 'S'/",
      "section": "section.additionalData",
      "step": 1,
      "type": "number",
      "value": 0,
      "visible": "/tuning?.jewelryInQuote == 'S'/"
    },
    "jewelryQuote": {
