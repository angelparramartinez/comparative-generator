          { "filter_expr": "insurance[\"risk\"].housingUse == 'MainResidence'", "hiring_status_expr": "\"INCLUDED\"", "value_expr": null, "modality_id": null, "lines": [{ "filter_expr": null, "text_expr": "'Linea A2'" }], "human_decision": null },
