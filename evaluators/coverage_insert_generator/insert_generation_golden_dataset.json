      "expected": { "product_company_id": 235, "covers": [] }
    },
    {
      "id": "UG-002",
      "description": "Objeto suelto sin array-wrapping -- debe devolverse tal cual, sin fallar.",
      "raw": { "product_company_id": 235, "covers": [] },
      "expected": { "product_company_id": 235, "covers": [] }
    }
  ],
